<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>RandomPlayDance_Recognizer</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="NAudio" Version="2.2.1" />
    <PackageReference Include="SoundFingerprinting" Version="14.1.0" />
    <PackageReference Include="SoundFingerprinting.Audio.NAudio" Version="8.0.0" />
  </ItemGroup>

  <ItemGroup>
    <None Update="Input\在此处放置待识别长音频">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="MusicLibrary\在此处放置音乐库歌曲">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
